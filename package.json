{
  "name": "onlyme-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --watch .env --watch src/controllers/.env --ext js,mjs,cjs,json,env src/server.js",
    "start": "node src/server.js",
    "lint": "eslint .",
    "test": "node --test --test-concurrency=1",
    "migrate:creator-verification": "node src/scripts/migrateCreatorVerification.js",
    "migrate:content:dry-run": "node src/scripts/migrateContentWorkflow.js --dry-run",
    "migrate:content": "node src/scripts/migrateContentWorkflow.js --apply",
    "analyze:publications": "node src/scripts/analyzeLegacyContentForPublications.js",
    "analyze:financial-migration": "node src/scripts/analyzeFinancialMigration.js",
    "analyze:wallet-reconciliation": "node src/scripts/analyzeWalletReconciliation.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "eslint": "^9.8.0",
    "globals": "^15.8.0",
    "nodemon": "^3.1.4"
  }
}

