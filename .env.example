﻿NODE_ENV=development
PORT=5000
NODE_ENV=development
PORT=3001
MONGODB_URI=mongodb://127.0.0.1:27017/onlyme_dev
CLIENT_URL=http://localhost:5173

JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Keep all three Cloudinary values on the backend only.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CONTENT_MAX_FILE_SIZE_BYTES=104857600

# Private local creator verification files. Never expose this directory with express.static.
VERIFICATION_STORAGE_ROOT=./private/creator-verifications
VERIFICATION_MAX_FILE_SIZE_BYTES=10485760

# Internal Stars testing only. Keep false outside controlled environments.
ENABLE_ADMIN_STAR_CREDITS=false

# Isolated test database only. Financial integration tests drop this database.
# MongoDB transactions require a replica set or Atlas test cluster.
TEST_MONGODB_URI=mongodb://127.0.0.1:27017/onlyme_financial_test?replicaSet=rs0

